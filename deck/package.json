{
  "name": "pass-deck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.cjs",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/dev.mjs",
    "start": "electron dist/main.cjs",
    "package:linux": "npm run build && electron-builder --linux AppImage",
    "test": "node --experimental-strip-types --test src/remote/remoteClient.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/xterm": "^6.0.0",
    "qrcode": "^1.5.4",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.2",
    "typescript": "~6.0.3"
  },
  "build": {
    "appId": "app.pass.deck",
    "productName": "Pass Deck",
    "asar": true,
    "files": ["dist/**/*", "package.json"],
    "directories": { "output": "release" },
    "linux": {
      "target": ["AppImage"],
      "category": "Development",
      "artifactName": "Pass-Deck-${version}-${arch}.${ext}"
    }
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
