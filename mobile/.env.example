# Public native OIDC client. These values are embedded in the app; never add a client secret.
EXPO_PUBLIC_PASS_OIDC_ISSUER=https://identity.example.com
EXPO_PUBLIC_PASS_OIDC_CLIENT_ID=pass-native
EXPO_PUBLIC_PASS_OIDC_AUDIENCE=pass-public-api

# Informational fallback shown in the manual pairing field. The QR remains authoritative.
EXPO_PUBLIC_PASS_RELAY_URL=https://relay.example.com
