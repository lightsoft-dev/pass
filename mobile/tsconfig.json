{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "allowImportingTsExtensions": true,
    "types": ["node"]
  },
  "include": [
    "expo-env.d.ts",
    ".expo/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
