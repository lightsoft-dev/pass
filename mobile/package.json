  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "postinstall": "node scripts/patch-expo-modules-jsi.mjs && node scripts/build-terminal-document.mjs",
