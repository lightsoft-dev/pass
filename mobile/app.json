{
  "expo": {
    "name": "Pass Remote",
    "slug": "pass-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "passremote",
    "userInterfaceStyle": "dark",
    "platforms": ["ios", "android"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.lightsoft.pass.remote"
    },
    "android": {
      "package": "app.lightsoft.pass.remote"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Pass Remote to scan a one-time pairing QR code.",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
